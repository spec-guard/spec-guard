{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/spec-guard/spec-guard/schemas/spec.schema.json",
  "title": "spec-guard spec front-matter",
  "description": "Optional YAML front-matter for a spec file. The prose body carries the sections (In-Scope, Out-of-Scope, Acceptance Criteria, Traceability).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "status": { "enum": ["PROPOSED", "APPROVED", "IMPLEMENTED", "SUPERSEDED"] },
    "supersedes": { "type": "string" },
    "supersededBy": { "type": "string" },
    "implements": { "type": "array", "items": { "type": "string" }, "description": "ADR/doc paths this spec implements." }
  },
  "required": ["status"]
}
